import sqlite3

action createH():
    try:
        conn = sqlite3.connect("mp-database.db")
        cursor = conn.cursor()
        cursor.execute(sql="CREATE TABLE usuarios (id INTEGER PRIMARY KEY, nome VARCHAR(100), senha VARCHAR(50), email VARCHAR(100), cpf TEXT, idade INTEGER, data_login TEXT DEFAULT CURRENT_TIMESTAMP);")

        result = cursor.fetchall()
        conn.commit()
        conn.close()

        if (result):
            post("ok")
        else:
            post("Erro")

    catch (e):
        post(e)

post(createH())