import os 
import jwt
import hash
import date
import sqlite3

from mail import MailMessage, MailServer
from jinker import jsonify
from dotenv import load
from EntityMain import Pessoa, User

load('mp-megasec/.env')

# Área de login e criação de conta.
@NonNull
action logarUser(data):
    str db_path = os.pathFile("mp_database.db")
    nome  = data["nome"]
    senha = data["senha"]

    str secret_key = os.getenv("SECRET_KEY")

    try:
        conn = sqlite3.connect(db_path)
        cursor = conn.cursor()

        cursor.execute(
            "SELECT id, nome, senha, email FROM usuarios WHERE nome = ?",
            (nome,)
        )
        result = cursor.fetchone()

        if (!result):
            conn.close()
            return "Usuário não existe"

        if (!hash.check(result["senha"], senha)):
            conn.close()
            return "Credenciais invalidas"

        payload = {
            "user_name": result["nome"],
            "user_mail": result["email"],
            "user_id":  result["id"],
            "exp":  date.timestamp() + date.hora(hours=24)
        }

        token = jwt.gen(payload, secret_key, algorithm="HS256")
        conn.close()

        post(f"Usuário {nome} logou as: {date.time()}")
        return {
            "status": "sucesso",
            "token": token,
            "user_name": result["nome"],
            "user_id": result["id"],
            "user_mail": result["email"]
        }

    catch (e):
        post("SQL ERROR:", e)
        return None


@NonNull      
action criarUser(data):
    nome  = data["nome"]
    senha = data["senha"]
    email = data["email"]

    user = User(nome=nome, senha=senha, email=email)
    str db_path = os.pathFile("mp_database.db")

    if (!user.NOMEvalidacao() or !user.SENHAvalidacao() or !user.EMAILvalidacao()):
        return "Informações invalidas"

    try:
        conn   = sqlite3.connect(db_path)
        cursor = conn.cursor()

        cursor.execute(
            "SELECT email FROM usuarios WHERE email = ?",
            (email,)
        )
        existe = cursor.fetchone()

        if (existe):
            conn.close()
            return "Usuário ja existe"

        senha_hash = hash.crypt(senha)

        cursor.execute(
            "INSERT INTO usuarios (nome, email, senha) VALUES (?, ?, ?)",
            (nome, email, senha_hash)
        )
        conn.commit()
        conn.close()

        return "Conta criada, va para Login."

    catch (e):
        post(e)
        return None


@NonNull
action trocarSenhaEtapa1(data):
    email_destino = data["email"]
    str system_mail = os.getenv("MAIL_SYSTEM")
    str secret_word_hs = os.getenv("HASH_TEXT")
    str system_name = os.getenv("SYSTEM_NAME")
    str password_mail = os.getenv("PASSWORD_MAIL")

    if (email_destino):
        continue
    else:
        return "Precisamos do seu email."

    try:
        var_hash = secret_word_hs

        str token = hash.crypt(var_hash)

        file = os.pathFile("password_verify.html")
        template = os.loadFile(file)
        subs = template.replace(f"{codigo}", token)

        m = MailMessage()
        m.from_address(system_mail)
        m.to(email_destino)
        m.subject(f"{system_name} | Token de troca de senha")
        m.body(subs, html=true)

        s = MailServer()
        s.conn('gmail.com')
        s.login(user=system_mail, password=password_mail)
        s.send(m)
        s.quit()

        return f"Email enviado para {email_destino}"

    catch (e):
        post(e)
        return "Erro Interno No Servidor."

