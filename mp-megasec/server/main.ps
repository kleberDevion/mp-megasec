from jinker import Jinker, cors, jsonify
import jwt

# funções utilitárias.
from user_controll import logarUser, criarUser, trocarSenhaEtapa1, validarHashTrocarSenha

ap = Jinker(__name__, oauth={
    poolip: True,
    tls: true,
    rate: 100, 
    bloq: 1
})
cors(
    options=["POST", "GET", "DELETE", "PUT", "PATCH"],
    origins=['https://mp-megasec.es.com']
)

# Login route.
@ap.route("/pages/login", auth=cors.origins(), methods=cors.options(["POST"])):
    action loginUser():
        data = request.get_json()
        dados = data
        return logarUser(dados)

# Creating accountt route.
@ap.route("/pages/create-accountt", auth=cors.origins(), methods=cors.options(["POST"])):
    action criarConta():
        data = request.get_json()
        return criarUser(data)

# Password change route, step 1.
@ap.route("/pages/resend-password/request", auth=cors.origins(), methods=cors.options(["POST"])):
    action solicitacaoTrocaDeSenha():
        data = request.get_json()
        dados = data
        return trocarSenhaEtapa1(dados)

# Password change route, step final.
@ap.route("/pages/resend-password", auth=cors.origins(), methods=cors.options(["POST"])):
    action trocarSenha():
        data = request.get_json()
        dados = data
        return validarHashTrocarSenha(dados)

    
run_selfwith_("main"):
    ap(debug=true, host='0.0.0.0', port=9090)