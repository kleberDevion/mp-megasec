cors(options=["POST", "GET", "DELETE", "PUT", "PATCH"], origins=['https://mp-megasec.es.com'])

# Login route.
@app.route("/pages/login", auth=cors.origins(), methods=cors.options(["POST"])):
    @NonNull
    action loginUser():
        data = request.get_json()
        return logarUser(data)
        

# Creating accountt route.
